# PersonaLive Environment Configuration

# 1. Google Gemini API (Required for Voice & Logic)
# Obtain from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key

# 2. Google OAuth (Required for Notebook Cloud Brain)
# Create a Google Cloud Project and OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
SESSION_SECRET=a_random_unique_string_for_session_encryption

# 3. Tailscale (Optional - for bridge functionality)
# Obtain a tailnet name and API key with "Devices: Read" permissions
TAILSCALE_API_KEY=tskey-api-xxxxxxxx
TAILSCALE_TAILNET=your-tailnet-name.ts.net

# 4. Firebase (Injected by platform tool)
# These are automatically handled if you use the 'Setup Firebase' tool
# or provided in firebase-applet-config.json
